# ---------------------------------------------------------
# 必須: 管理者として認識するクライアントのグローバルIPアドレス
# ---------------------------------------------------------
ADMIN_IP=0.0.0.0

# ---------------------------------------------------------
# オプション
# ---------------------------------------------------------
# WebSocket サーバーのリッスンポート (デフォルト: 10000)
PORT=10000

# ログファイルのパス (デフォルト: /data/messages.txt)
LOG_FILE=/data/messages.txt

# ログレベル: DEBUG | INFO | WARNING | ERROR (デフォルト: INFO)
LOG_LEVEL=INFO
